# =====================================================================
# JWT AUTHENTICATION
# =====================================================================
JWT_SECRET_KEY=change_me_to_a_long_random_secret_in_production
ACCESS_TOKEN_EXPIRE_DAYS=7

# =====================================================================
# DATABASE CONFIGURATION
# =====================================================================
# Local SQLite Dev database:
DATABASE_URL=sqlite:///./freshsave_local_dev.db
# Production PostgreSQL (e.g. Supabase, Railway):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# =====================================================================
# CORS ORIGINS CONFIGURATION
# =====================================================================
# Comma-separated list of allowed origins. Use '*' to allow all.
CORS_ORIGINS=*
# Production Example:
# CORS_ORIGINS=https://expirygo.vercel.app,https://another-domain.com

# =====================================================================
# SUPABASE CONFIGURATION (Postgres & Storage)
# =====================================================================
# Why it's needed: Provides PostgreSQL for production database and file storage for product images.
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-public-key

# =====================================================================
# CACHE CONFIGURATION
# =====================================================================
# Why it's needed: Used for fast caching (storing active OTPs temporarily, database queries, and WebSocket pub/sub).
# Requires a Redis server running on your machine or cloud.
REDIS_URL=redis://localhost:6379

# =====================================================================
# EXTERNAL INTEGRATIONS & APIS (Optional / Fallback Enabled)
# =====================================================================
# Google Gemini (AI Optimization)
# Why it's needed: Used to optimize product details, categorize items, or generate descriptions.
GEMINI_API_KEY=your-gemini-api-key

# OpenAI (Vision AI)
# Why it's needed: Used to process images (scanning expiration dates and reading labels from uploaded packages).
OPENAI_API_KEY=your-openai-api-key

# Fast2SMS (SMS Service)
# Why it's needed: Indian SMS gateway used to dispatch OTPs to users' mobile phones for verification.
FAST2SMS_API_KEY=your-fast2sms-api-key

# =====================================================================
# SMTP OUTBOUND NOTIFICATION SETTINGS (Optional / Fallback Enabled)
# =====================================================================
# Why it's needed: Allows the application to send email alerts (e.g., "Your product is expiring soon!").
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SENDER=no-reply@expirygo.com

# =====================================================================
# APPLICATION MODE
# =====================================================================
DEBUG=False

# API Base URL (optional fallback for local uploaded image references)
API_BASE_URL=http://localhost:8000
